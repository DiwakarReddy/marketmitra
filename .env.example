# ============================================
# MarketMitra — Production Environment
# ============================================

# ---- Database ----
# Local Postgres (development)
# DATABASE_URL="postgresql://marketmitra:devpass@localhost:5432/marketmitra"
#
# Neon (production — get from https://neon.tech)
# Use the POOLED connection string (has -pooler in hostname)
DATABASE_URL="postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/marketmitra?sslmode=require"
# Set to true when using Neon serverless driver
USE_NEON_ADAPTER="true"

# ---- NextAuth ----
NEXTAUTH_URL="https://app.marketmitra.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ---- Encryption ----
# Used to AES-256-GCM encrypt per-tenant credentials in DB
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ---- Admin ----
# Email that can access /admin pages
ADMIN_EMAIL="you@yourdomain.com"

# ---- AI Provider ----
# At least ONE required (defaults to Hinglish template if none)
# Google Gemini (free tier: 1500 req/day)
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
# OpenAI (paid, ~$5 minimum)
OPENAI_API_KEY=""

# ---- WhatsApp Business API ----
# Provider: 'meta' | 'aisensy' | '360dialog' | 'twilio' — leave empty for MOCK mode
WHATSAPP_PROVIDER="meta"
# Meta Cloud API
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_APP_SECRET=""
# AiSensy / 360dialog
# WHATSAPP_API_KEY=""

# ---- Cron security ----
# Used to authenticate Vercel Cron / external cron calls
# Generate: openssl rand -hex 32
CRON_SECRET="generate-with-openssl-rand-hex-32"

# ---- Optional integrations ----
# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Google AI for additional per-tenant key support
# GOOGLE_AI_API_KEY=""

# Sentry (error monitoring)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# Upstash Redis (for rate limiting + cache at scale)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
